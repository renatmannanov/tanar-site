# PRODUCTION env for docker-compose.prod.yml.
# Copy to `.env` on the server (gitignored) and fill in REAL secrets.
# Never commit the filled-in .env.

# Deterministic compose project name → volume names are stable across clones
# (backup.sh relies on `tanar-site_product-images`). Do not change.
COMPOSE_PROJECT_NAME=tanar-site

# --- Postgres (runs in the `postgres` container) ---------------------------
POSTGRES_USER=tanar
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=tanar

# --- App DB connection -----------------------------------------------------
# Host is the compose SERVICE name `postgres` on internal port 5432
# (NOT 5442 — that's the local dev host mapping only).
# WARNING: the password here MUST equal POSTGRES_PASSWORD above. They are the
# same secret in two places — if they drift, web can't connect (500s).
DATABASE_URL=postgres://tanar:change-me-strong-db-password@postgres:5432/tanar

# --- Admin auth (single user, no DB) ---------------------------------------
# ADMIN_SESSION_SECRET must be >= 32 chars (HMAC key) or admin-auth throws.
# Generate each secret with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
ADMIN_PASSWORD=change-me-strong-admin-password
ADMIN_SESSION_SECRET=change-me-to-a-random-32-plus-character-secret

# --- Domain (Caddy auto-SSL) -----------------------------------------------
# The domain (or subdomain) whose A-record points at this VPS. Caddy issues a
# Let's Encrypt cert for it. Must resolve to this server BEFORE first https hit.
DOMAIN=example.kz
