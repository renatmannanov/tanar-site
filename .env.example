# Local Postgres via docker-compose (see docker-compose.yml).
# Copy this file to .env.local (gitignored) and adjust if needed.
DATABASE_URL=postgres://tanar:tanar_dev_pw@localhost:5442/tanar_dev
DATABASE_TEST_URL=postgres://tanar:tanar_test_pw@localhost:5443/tanar_test

# Admin auth (single user, no DB).
# ADMIN_SESSION_SECRET must be at least 32 characters (HMAC key). Generate e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
ADMIN_PASSWORD=change-me-strong-password
ADMIN_SESSION_SECRET=change-me-to-a-random-32-plus-character-secret

# Gemini API key — AI photo generation in admin (photogen / nano-banana).
# Optional for build; required only when using the "generate photo" buttons.
GEMINI_API_KEY=
